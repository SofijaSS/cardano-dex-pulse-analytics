# Production defaults use public endpoints. Override any URL to route through a
# managed proxy or authenticated provider without changing dashboard code.
DEFILLAMA_VOLUME_URL=https://api.llama.fi/overview/dexs/cardano?excludeTotalDataChart=false&excludeTotalDataChartBreakdown=false
DEFILLAMA_PROTOCOLS_URL=https://api.llama.fi/protocols
COINGECKO_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=cardano&vs_currencies=usd&include_last_updated_at=true
COINBASE_PRICE_URL=https://api.coinbase.com/v2/prices/ADA-USD/spot
MINSWAP_POOLS_URL=https://api-mainnet-prod.minswap.org/v1/pools/metrics
WINGRIDERS_STATS_URL=https://api.mainnet.wingriders.com/v1/defillama
SUNDAESWAP_GRAPHQL_URL=https://api.sundae.fi/graphql
SPLASH_STATS_URL=https://analytics.splash.trade/platform-api/v1/platform/stats
MUESLISWAP_VOLUME_URL=https://aggregator-analytics-v2.muesliswap.com/muesli-protocol-volume?interval=day&days=60
MUESLISWAP_TVL_URL=https://aggregator-analytics-v2.muesliswap.com/muesli-tvl?days=2
VYFINANCE_STATS_URL=https://api-v3.vyfi.io/fetchmaster?data=allPoolsAnalytics
DANO_STATS_URL=https://danogo-gateway.tekoapis.com/api/v1/defillama-dimensions
DELTA_STATS_URL=https://api-internal-metrics.deltadefi.io/public/volume/daily
SATURN_STATS_URL=https://api.saturnswap.io/v1/defillama/volume

# Public, keyless token-market sources used by the protected /tokens workspace.
MINSWAP_API_URL=https://api-mainnet-prod.minswap.org

# Successful API responses are cached by the server route for this many seconds.
DATA_CACHE_SECONDS=300
DATA_STALE_SECONDS=1800
TOKEN_CACHE_SECONDS=60
SOURCE_FETCH_TIMEOUT_MS=7000
SOURCE_FETCH_ATTEMPTS=2

# Development only. The UI displays a permanent warning while enabled.
USE_MOCK_DATA=false

# Optional public deployment URL, used by social metadata when configured.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional application-level access control, independent of ChatGPT sign-in.
# Keep the hash and secret in the hosting secret store, never in source control.
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_AUTH_USERNAME=analytics
DASHBOARD_AUTH_PASSWORD_HASH=hmac_sha256:replace-with-generated-verifier
DASHBOARD_AUTH_SECRET=replace-with-at-least-32-random-characters
